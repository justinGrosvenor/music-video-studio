{
  "name": "music-video-studio",
  "version": "0.0.1",
  "description": "Audio-aware AI timeline editor for music videos.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/justinGrosvenor/music-video-studio.git"
  },
  "keywords": [
    "music-video",
    "timeline-editor",
    "generative-video",
    "audio-analysis",
    "ffmpeg"
  ],
  "scripts": {
    "dev": "pnpm --filter @mvs/shared build && pnpm -r --parallel run dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:web": "pnpm --filter @mvs/web dev",
    "dev:api": "pnpm --filter @mvs/api dev",
    "dev:shared": "pnpm --filter @mvs/shared dev",
    "dev:analyzer": "cd modal && .venv/bin/python local_server.py",
    "test": "vitest run"
  },
  "devDependencies": {
    "happy-dom": "^20.9.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
