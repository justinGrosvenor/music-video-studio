{
  "name": "music-video-studio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @mvs/shared build && pnpm -r --parallel run dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:web": "pnpm --filter @mvs/web dev",
    "dev:api": "pnpm --filter @mvs/api dev",
    "dev:shared": "pnpm --filter @mvs/shared dev",
    "dev:analyzer": "cd modal && .venv/bin/python local_server.py"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  }
}
