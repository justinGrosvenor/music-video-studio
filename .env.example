# Fill these in. Empty values are tolerated; the server boots and warns.

RUNWAYML_API_SECRET=

# Set this once you've run `modal deploy modal/audio_analysis.py`.
# Format: https://<workspace>--music-video-studio-audio-analyze.modal.run
MODAL_AUDIO_URL=

# Local dev defaults — change for prod.
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:5173

# Storage backend: "local" writes to ./storage on disk, "s3" pushes to AWS.
# Local is fine for dev; production should use s3 to survive container restarts.
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=
# Optional. If using CloudFront in front of the bucket, set the distribution
# domain here, e.g. https://d1234.cloudfront.net. Otherwise virtual-hosted-style
# S3 URLs are used.
S3_PUBLIC_URL_BASE=
